<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEEEEE"
    tools:context=".MainActivity">

    <Button
        android:id="@+id/createJanButton"
        android:layout_width="325dp"
        android:layout_height="255dp"
        android:backgroundTint="#D7D2CB"
        android:text=""
        app:cornerRadius="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.544"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView4" />

    <Button
        android:id="@+id/showHistoryButton"
        android:layout_width="325dp"
        android:layout_height="255dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="#D7D2CB"
        android:text=""
        app:cornerRadius="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.545"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/createJanButton"
        app:layout_constraintVertical_bias="0.162" />

    <ImageView
        android:id="@+id/createJanImage"
        android:layout_width="375dp"
        android:layout_height="232dp"

        app:layout_constraintBottom_toBottomOf="@+id/createJanButton"
        app:layout_constraintEnd_toEndOf="@+id/createJanButton"
        app:layout_constraintStart_toStartOf="@+id/createJanButton"
        app:layout_constraintTop_toTopOf="@+id/createJanButton"
        app:layout_constraintVertical_bias="0.434"
        app:srcCompat="@drawable/barcode" />

    <ImageView
        android:id="@+id/imageView4"
        android:layout_width="380dp"
        android:layout_height="165dp"
        android:layout_marginTop="64dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/toru_jan_logo" />

    <ImageView
        android:id="@+id/imageView5"
        android:layout_width="197dp"
        android:layout_height="268dp"
        app:layout_constraintBottom_toBottomOf="@+id/showHistoryButton"
        app:layout_constraintEnd_toEndOf="@+id/showHistoryButton"
        app:layout_constraintStart_toStartOf="@+id/showHistoryButton"
        app:layout_constraintTop_toTopOf="@+id/showHistoryButton"
        app:srcCompat="@drawable/history" />

</androidx.constraintlayout.widget.ConstraintLayout>