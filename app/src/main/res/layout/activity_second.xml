<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEEEEE"
    tools:context=".SecondActivity">


    <Button
        android:id="@+id/cameraInputButton"
        android:layout_width="306dp"
        android:layout_height="228dp"
        android:layout_marginTop="168dp"
        android:backgroundTint="#D7D2CB"
        android:text=""
        app:cornerRadius="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.504"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/manualInputButton"
        android:layout_width="307dp"
        android:layout_height="228dp"
        android:layout_marginTop="56dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#D7D2CB"
        android:text=""
        app:cornerRadius="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.509"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cameraInputButton"
        app:layout_constraintVertical_bias="0.0" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="269dp"
        android:layout_height="188dp"
        app:layout_constraintBottom_toBottomOf="@+id/cameraInputButton"
        app:layout_constraintEnd_toEndOf="@+id/cameraInputButton"
        app:layout_constraintStart_toStartOf="@+id/cameraInputButton"
        app:layout_constraintTop_toTopOf="@+id/cameraInputButton"
        app:srcCompat="@drawable/camera" />

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="258dp"
        android:layout_height="184dp"
        app:layout_constraintBottom_toBottomOf="@+id/manualInputButton"
        app:layout_constraintEnd_toEndOf="@+id/manualInputButton"
        app:layout_constraintStart_toStartOf="@+id/manualInputButton"
        app:layout_constraintTop_toTopOf="@+id/manualInputButton"
        app:srcCompat="@drawable/touch" />

    <Button
        android:id="@+id/homeButton"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="#D7D2CB"
        android:text=""
        app:cornerRadius="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.046"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imageView3"
        android:layout_width="66dp"
        android:layout_height="54dp"
        app:layout_constraintBottom_toBottomOf="@+id/homeButton"
        app:layout_constraintEnd_toEndOf="@+id/homeButton"
        app:layout_constraintStart_toStartOf="@+id/homeButton"
        app:layout_constraintTop_toTopOf="@+id/homeButton"
        app:srcCompat="@drawable/home" />
</androidx.constraintlayout.widget.ConstraintLayout>